<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="chat-body" style="display: block;">
  <div class="app-container" style="flex-direction: column; overflow-y: auto; padding: 2rem;">
    <header class="chat-header" style="background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1); display:flex; justify-content: space-between;">
      <h2>Admin Dashboard</h2>
      <div>
        <a href="/chat" class="logout-btn" style="color: var(--accent-color); background: rgba(14, 165, 233, 0.1); margin-right: 1rem;">Back to Chat</a>
        <a href="/auth/logout" class="logout-btn">Logout</a>
      </div>
    </header>

    <div style="display: flex; gap: 2rem; margin-top: 2rem;">
      <div class="auth-container" style="max-width: 250px; text-align: left; padding: 1.5rem;">
        <h3 style="color: var(--text-muted); font-size: 0.8rem; margin: 0 0 0.5rem 0;">TOTAL REGISTERED USERS</h3>
        <h1 style="color: var(--text-main); font-size: 2.5rem; margin: 0;"><%= stats.totalUsers %></h1>
      </div>
      <div class="auth-container" style="max-width: 250px; text-align: left; padding: 1.5rem;">
        <h3 style="color: var(--text-muted); font-size: 0.8rem; margin: 0 0 0.5rem 0;">ACTIVE USERS (Logged in at least once)</h3>
        <h1 style="color: var(--text-main); font-size: 2.5rem; margin: 0;"><%= stats.activeUsers %></h1>
      </div>
    </div>

    <div class="auth-container" style="max-width: 100%; margin-top: 2rem; padding: 1.5rem; text-align:left;">
      <h3 style="color: var(--text-muted); font-size: 0.8rem; margin: 0 0 1.5rem 0;">LIVE ACTIVITY TRACKER (Cron Captured, 24h Data)</h3>
      <canvas id="activityChart" height="60"></canvas>
    </div>
  </div>

  <script>
    // EJS safely injects the JSON string of our snapshot array from MongoDB
    const snapshots = <%- JSON.stringify(snapshots) %>;
    
    // If no snapshots yet, we can add a fake one right now to see the chart shape
    if (snapshots.length === 0) {
      snapshots.push({ createdAt: new Date().toISOString(), onlineCount: 0 });
    }
    
    // Map data for Chart.js
    const labels = snapshots.map(s => new Date(s.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}));
    const dataPoints = snapshots.map(s => s.onlineCount);

    const ctx = document.getElementById('activityChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Concurrent Online Users',
          data: dataPoints,
          backgroundColor: 'rgba(14, 165, 233, 0.5)',
          borderColor: 'rgba(14, 165, 233, 1)',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { 
              precision: 0, 
              color: '#94a3b8' 
            },
            grid: { color: 'rgba(255, 255, 255, 0.05)' }
          },
          x: {
            ticks: { color: '#94a3b8' },
            grid: { display: false }
          }
        }
      }
    });

  </script>
</body>
</html>
