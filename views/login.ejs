<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - RealTime Chat</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="auth-container">
    <h1>Welcome Back</h1>
    <p>Sign in to continue to chat</p>
    
    <!-- We dynamically show a message if one is passed from the server -->
    <% if (locals.msg) { %>
      <div class="alert alert-success">
        <%= msg %>
      </div>
    <% } %>

    <!-- The form sends a POST request to our auth API route -->
    <form action="/auth/login" method="POST">
      <div class="input-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autocomplete="username" placeholder="e.g. johndoe">
      </div>
      
      <div class="input-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      
      <button type="submit" class="btn">Sign In</button>
    </form>
    
    <div class="links">
      Don't have an account? <a href="/auth/register">Register</a>
    </div>
  </div>
</body>
</html>
