<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - RealTime Chat</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="chat-body">
  <div class="app-container">
    
    <!-- Sidebar for Rooms -->
    <aside class="sidebar">
      <div class="sidebar-header" style="flex-direction: column; align-items: flex-start; gap: 0.75rem;">
        <h2 style="margin: 0;">Hi, <%= user.username %>!</h2>
        <div style="display: flex; gap: 0.5rem; width: 100%;">
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="logout-btn" style="background: rgba(14, 165, 233, 0.1); color: var(--accent-color); flex: 1; text-align: center;">Admin</a>
          <% } %>
          <a href="/auth/logout" class="logout-btn" style="flex: 1; text-align: center;">Logout</a>
        </div>
      </div>
      
      <div style="padding: 0 1rem;">
        <form id="private-chat-form" style="display: flex; gap: 0.5rem; margin-top: 1rem;">
          <input type="text" id="search-username" placeholder="Search username..." autocomplete="off" style="flex: 1; padding: 0.5rem; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; width:100%;" required />
          <button type="submit" style="background: rgba(14, 165, 233, 0.8); border: none; border-radius: 4px; color: white; cursor: pointer; padding: 0.5rem 0.75rem;">+</button>
        </form>
      </div>

      <div class="room-list">
        <h3>Your Chats</h3>
        <% if (rooms.length === 0) { %>
          <p class="empty-state" style="color: var(--text-muted); font-size: 0.875rem;">No rooms joined yet. Try creating one!</p>
        <% } %>
        <ul id="rooms-ul" style="list-style: none; padding: 0; margin: 0;">
          <% rooms.forEach(room => { %>
            <li class="room-item" data-room-id="<%= room._id %>" data-room-name="<%= room.name || 'Private Chat' %>">
              <span class="room-name"><%= room.name || 'Private Chat' %></span>
              <span class="room-type"><%= room.type %></span>
            </li>
          <% }) %>
        </ul>
      </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="chat-main hidden" id="chat-window">
      <header class="chat-header">
        <h2 id="current-room-name">Select a room to start chatting</h2>
      </header>
      
      <div class="messages-container" id="messages-container">
        <!-- Messages will be injected here via Socket.IO -> JS -->
      </div>
      
      <div class="typing-indicator hidden" id="typing-indicator">
        <span id="typing-users-text"></span>
        <div class="bouncing-dots">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
      </div>
      
      <form id="chat-form" class="chat-input-area">
        <input type="text" id="message-input" placeholder="Type a message..." autocomplete="off" disabled />
        <button type="submit" id="send-btn" disabled>
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
      </form>
    </main>

    <!-- Empty State prior to selecting a room -->
    <main class="chat-main empty-chat" id="empty-chat-state">
      <div class="empty-message">
        <svg viewBox="0 0 24 24" width="64" height="64" stroke="var(--text-muted)" stroke-width="1" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <h2>Welcome to RealTime Chat</h2>
        <p>Select a room from the sidebar to start messaging.</p>
      </div>
    </main>

  </div>

  <!-- Expose backend identifiers to the frontend gracefully -->
  <script>
    window.CURRENT_USER = {
      userId: '<%= user.userId %>',
      username: '<%= user.username %>',
      role: '<%= user.role %>'
    };
  </script>
  
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/chat.js"></script>
</body>
</html>
